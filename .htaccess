# Apache .htaccess — Front Controller & Security Rules
# Place this in the D:\lory-hiring\ project root
# Laragon uses Apache, so this file is automatically read.

# Options -Indexes          # Disable directory listing
# Options -MultiViews       # Prevent content negotiation

# ─── Enable URL Rewriting ────────────────────────────────────
RewriteEngine On
RewriteBase /

# ─── Security: Block access to sensitive files ───────────────
RewriteRule ^\.env$               - [F,L]
RewriteRule ^composer\.(json|lock)$ - [F,L]
RewriteRule ^config/.*$           - [F,L]
RewriteRule ^app/.*$              - [F,L]
RewriteRule ^database/.*$         - [F,L]
RewriteRule ^logs/.*$             - [F,L]
RewriteRule ^vendor/.*$           - [F,L]

# ─── Serve storage files (lorry photos) via PHP proxy ────────
# Requests to /storage/ are served by serve.php for access control
RewriteRule ^storage/(.*)$        serve.php?file=$1 [QSA,L]

# ─── Admin panel routes to admin/index.php ───────────────────
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^admin(/.*)?$         admin/index.php [L,QSA]

# ─── All other requests go to the main index.php ─────────────
# Skip if the request is for a real file (public/css, public/js, etc.)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$                index.php [L,QSA]

# ─── Security Headers ─────────────────────────────────────────
<IfModule mod_headers.c>
    # Prevent clickjacking
    Header always set X-Frame-Options "SAMEORIGIN"
    # Prevent MIME-type sniffing
    Header always set X-Content-Type-Options "nosniff"
    # Enable XSS protection in older browsers
    Header always set X-XSS-Protection "1; mode=block"
    # Referrer policy
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ─── Compression (improves page load speed) ──────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css
    AddOutputFilterByType DEFLATE application/javascript application/json
</IfModule>

# ─── Browser Caching for static assets ───────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg  "access plus 1 month"
    ExpiresByType image/png   "access plus 1 month"
    ExpiresByType image/webp  "access plus 1 month"
    ExpiresByType text/css    "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
</IfModule>
