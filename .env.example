# ============================================================
# Online Lorries Hiring System — Environment Variables
# Copy this file to .env and fill in your real values
# NEVER commit the .env file to Git
# ============================================================

# ------------------------------------------------------------
# Application Settings
# ------------------------------------------------------------
APP_NAME="Online Lorries Hiring System"
APP_URL=http://lory-hiring.test
APP_ENV=development
# Generate a 32-char random key: php -r "echo bin2hex(random_bytes(16));"
APP_KEY=your-random-32-char-secret-key-here

# ------------------------------------------------------------
# Database (Laragon MySQL defaults)
# ------------------------------------------------------------
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=olhs_db
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# ------------------------------------------------------------
# Google Maps API (Free Tier)
# Get your key from: https://console.cloud.google.com
# Enable: Maps JavaScript API + Distance Matrix API + Places API
# ------------------------------------------------------------
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# ------------------------------------------------------------
# Gmail SMTP (Real Email via PHPMailer)
# Use a Gmail App Password (not your real Gmail password)
# Enable 2FA on Gmail → Security → App Passwords → Generate
# ------------------------------------------------------------
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_ENCRYPTION=tls
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password
MAIL_FROM_NAME="OLHS Platform"
MAIL_FROM_EMAIL=your-email@gmail.com

# ------------------------------------------------------------
# Platform Business Settings
# ------------------------------------------------------------
COMMISSION_RATE=8
MIN_WITHDRAWAL=5000
BOOKING_TIMEOUT_HOURS=24
